# ============================================================================
# Required — local dev + production
# ============================================================================

# Supabase (project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Direct Postgres connection for Drizzle migrations + server-side queries
# Found in Supabase project settings → database → connection string (Transaction pooler)
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# ============================================================================
# Optional — production only
# ============================================================================

# MCP session storage. mcp-handler falls back to in-memory if unset, which is
# fine for a single Node process but flaky across serverless invocations. Set
# this in Vercel for reliable multi-request MCP flows. Upstash free tier is
# plenty for personal use.
# REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# ============================================================================
# Future integrations (not wired yet)
# ============================================================================

# Email sending (Resend) — Campaigns Send, send_quote, send_email
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=hello@zarco.uk

# Microsoft Graph (Outlook inbox sync)
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_TENANT_ID=

# Granola webhook (incoming meeting transcripts)
# GRANOLA_WEBHOOK_SECRET=
